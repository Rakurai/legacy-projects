# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=4010
DB_NAME=legacy_og_docs
DB_USER=postgres
DB_PASSWORD=postgres

# Project Paths
PROJECT_ROOT=/path/to/legacy/repo
ARTIFACTS_DIR=/path/to/legacy/repo/.ai/artifacts

# Logging
LOG_LEVEL=INFO

# ── Embedding Provider ────────────────────────────────────────────────
# Set EMBEDDING_PROVIDER to enable semantic search.
# Omit (or leave commented) for keyword-only mode.

# Provider selection: "local" (bundled ONNX) or "hosted" (OpenAI-compatible)
EMBEDDING_PROVIDER=local

# Vector dimension (must match provider model output; 768 for bge-base-en-v1.5)
EMBEDDING_DIMENSION=768

# Local provider config (only when EMBEDDING_PROVIDER=local)
EMBEDDING_LOCAL_MODEL=BAAI/bge-base-en-v1.5

# Hosted provider config (only when EMBEDDING_PROVIDER=hosted)
# EMBEDDING_BASE_URL=http://localhost:4000/v1
# EMBEDDING_API_KEY=lm-studio
# EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b
