# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=4010
DB_NAME=legacy_og_docs
DB_USER=postgres
DB_PASSWORD=postgres

# Project Paths
PROJECT_ROOT=/path/to/legacy/repo
ARTIFACTS_DIR=/path/to/legacy/repo/.ai/artifacts

# Logging
LOG_LEVEL=INFO

# Optional: Embedding Endpoint (OpenAI-compatible API)
# If not set, semantic search will degrade to keyword-only mode
# EMBEDDING_BASE_URL=http://localhost:4000/v1
# EMBEDDING_API_KEY=lm-studio
# EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b
